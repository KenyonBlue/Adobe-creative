# OpenAI API key (optional — mock generation used when unset)
# Either variable name works:
OPENAI_API_KEY=
# adobe-fde-creative-automation-poc=

# Image model: gpt-image-1 (default), gpt-image-1.5, dall-e-3, dall-e-2
# If your key doesn't support a model, the backend auto-falls back to gpt-image-1 then dall-e-2.
OPENAI_IMAGE_MODEL=gpt-image-1

# Server
PORT=3001
NODE_ENV=development

# Storage paths (relative to backend root)
STORAGE_ROOT=./storage
OUTPUTS_ROOT=./outputs
UPLOADS_ROOT=./uploads

# Frontend (for Docker)
VITE_API_URL=http://localhost:3001
